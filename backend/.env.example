# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/agrotrace_db
# For SQLite (development):
# DATABASE_URL=sqlite:///agrotrace.db

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG=True

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# Email Configuration (for password reset OTP)
# Use a Gmail address with 2-Step Verification enabled, then generate an App Password.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
MAIL_USE_TLS=True

# Google Sign-In
# Create a Web application client ID in Google Cloud Console.
# Add your frontend origin such as http://localhost:5500 or http://127.0.0.1:5500
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# QR Code Configuration
QR_CODE_VERSION=1
QR_CODE_ERROR_CORRECTION=L

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# AWS Configuration (if using S3 for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=agrotrace-uploads
AWS_REGION=us-east-1
